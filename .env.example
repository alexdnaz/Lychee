## Copy this file to ".env" and fill in the values before running the app.
## The ".env" file is git-ignored and should not be committed.

# Your OpenAI API Key (for Codex/GPT calls)
OPENAI_API_KEY=your-openai-api-key-here

# Flask application secret key (used for session signing)
FLASK_SECRET_KEY=your-flask-secret-key-here
